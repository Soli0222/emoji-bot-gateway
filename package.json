{
  "name": "emoji-bot-gateway",
  "version": "1.0.0",
  "description": "Misskey Emoji Bot Gateway - AI-powered emoji generation and registration",
  "main": "dist/main.js",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "hono": "^4.12.18",
    "ioredis": "^5.10.1",
    "misskey-js": "2026.5.1",
    "openai": "^6.37.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
